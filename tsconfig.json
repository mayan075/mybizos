{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@hararai/db": ["./packages/db/src"],
      "@hararai/shared": ["./packages/shared/src"],
      "@hararai/ui": ["./packages/ui/src"],
      "@hararai/ai": ["./packages/ai/src"],
      "@hararai/email": ["./packages/email/src"],
      "@hararai/integrations": ["./packages/integrations/src"]
    }
  }
}
