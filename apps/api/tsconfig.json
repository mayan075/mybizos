{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../../",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@/*": ["./src/*"],
      "@hararai/db": ["../../packages/db/src"],
      "@hararai/shared": ["../../packages/shared/src"],
      "@hararai/ai": ["../../packages/ai/src"],
      "@hararai/email": ["../../packages/email/src"],
      "@hararai/integrations": ["../../packages/integrations/src"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
