# ──────────────────────────────────────────────
# HararAI API — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────

# Required
NODE_ENV=production
PORT=3001
DATABASE_URL=postgresql://user:pass@localhost:5432/mybizos
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-32-character-minimum-secret-here
CORS_ORIGIN=https://yourdomain.com
APP_URL=https://api.yourdomain.com

# Integrations (optional — features degrade gracefully without these)

# Twilio — SMS & Voice
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Anthropic — AI features (Claude)
ANTHROPIC_API_KEY=

# Resend — Transactional email
RESEND_API_KEY=
RESEND_DEFAULT_FROM=HararAI <notifications@yourdomain.com>

# Stripe — Payments & billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# Vapi — AI voice agent
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=

# Google OAuth — Calendar & Gmail integrations
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Scheduler — Enable background job scheduler (true/false)
ENABLE_SCHEDULER=false
